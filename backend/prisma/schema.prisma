generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  passwordHash  String
  createdAt     DateTime        @default(now())
  transactions     Transaction[]
  personEvents     CalendarEvent[]
  createdEvents    CalendarEvent[]    @relation("EventCreator")
  shoppingItems    ShoppingListItem[]
  pushSubscriptions      PushSubscription[]
  notificationsReceived  NotificationLog[]
}

model PaymentMethod {
  id           String            @id @default(cuid())
  name         String
  type         PaymentMethodType
  isActive     Boolean           @default(true)
  transactions Transaction[]
}

enum PaymentMethodType {
  DEBIT
  CREDIT
}

model Category {
  id           String        @id @default(cuid())
  name         String
  icon         String
  color        String
  isDefault    Boolean       @default(true)
  transactions Transaction[]
}

model Transaction {
  id               String          @id @default(cuid())
  user             User            @relation(fields: [userId], references: [id])
  userId           String
  paymentMethod    PaymentMethod   @relation(fields: [paymentMethodId], references: [id])
  paymentMethodId  String
  category         Category?       @relation(fields: [categoryId], references: [id])
  categoryId       String?
  type             TransactionType
  originalAmount   Int
  originalCurrency Currency
  amountDkk        Int
  exchangeRate     Decimal?        @db.Decimal(10, 6)
  description      String?
  occurredAt       DateTime
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum Currency {
  DKK
  BRL
}

model ExchangeRate {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  fromCurrency Currency
  toCurrency   Currency
  rate         Decimal  @db.Decimal(14, 8)
  note         String?
  fetchedAt    DateTime @default(now())

  @@unique([date, fromCurrency, toCurrency])
}

model CalendarEvent {
  id             String         @id @default(cuid())
  title          String
  type           EventType
  person         User?          @relation(fields: [personId], references: [id])
  personId       String?
  startAt        DateTime
  allDay         Boolean        @default(true)
  recurrence     RecurrenceType @default(NONE)
  recurrenceDays Int[]          @default([])
  description    String?
  createdBy      User           @relation("EventCreator", fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum EventType {
  BIRTHDAY
  PAYMENT_DUE
  SPORTS
  EXERCISE
  GENERAL
}

enum RecurrenceType {
  NONE
  YEARLY
  WEEKLY
}

model ShoppingListItem {
  id            String      @id @default(cuid())
  user          User        @relation(fields: [userId], references: [id])
  userId        String
  name          String
  checked       Boolean     @default(false)
  matchedOffer  FlyerOffer? @relation(fields: [matchedOfferId], references: [id])
  matchedOfferId String?
  matchedAt     DateTime?
  matchNote     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model FlyerOffer {
  id           String             @id @default(cuid())
  externalId   String             @unique
  dealerId     String
  dealerName   String
  name         String
  priceOre     Int
  prePriceOre  Int?
  validFrom    DateTime
  validUntil   DateTime
  fetchedAt    DateTime           @default(now())
  items        ShoppingListItem[]
}

model AiUsageLog {
  id             String   @id @default(cuid())
  model          String
  inputTokens    Int
  outputTokens   Int
  itemsProcessed Int
  createdAt      DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model NotificationLog {
  id              String            @id @default(cuid())
  type            NotificationType
  calendarEventId String?
  reminderStage   ReminderStage?
  pokeMessageId   String?
  fromUserId      String?
  toUserId        String
  toUser          User              @relation(fields: [toUserId], references: [id])
  title           String
  body            String
  read            Boolean           @default(false)
  sentAt          DateTime          @default(now())
}

enum NotificationType {
  EVENT_REMINDER
  POKE
}

enum ReminderStage {
  DAY_BEFORE
  DAY_OF
}
