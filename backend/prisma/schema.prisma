generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  passwordHash  String
  createdAt     DateTime        @default(now())
  transactions     Transaction[]
  personEvents     CalendarEvent[]
  createdEvents    CalendarEvent[]    @relation("EventCreator")
  shoppingItems    ShoppingListItem[]
  pushSubscriptions      PushSubscription[]
  notificationsReceived  NotificationLog[]
  maintenanceLogs  MaintenanceLog[]
  workoutLogs      WorkoutLog[]
  weeklyResultsWon WeeklyResult[]  @relation("WeeklyWinner")
  interests   UserInterest[]
  relevances  EventSuggestionRelevance[]
}

model PaymentMethod {
  id           String            @id @default(cuid())
  name         String
  type         PaymentMethodType
  isActive     Boolean           @default(true)
  transactions Transaction[]
}

enum PaymentMethodType {
  DEBIT
  CREDIT
}

model Category {
  id           String        @id @default(cuid())
  name         String
  icon         String
  color        String
  isDefault    Boolean       @default(true)
  transactions Transaction[]
}

model Transaction {
  id               String          @id @default(cuid())
  user             User            @relation(fields: [userId], references: [id])
  userId           String
  paymentMethod    PaymentMethod   @relation(fields: [paymentMethodId], references: [id])
  paymentMethodId  String
  category         Category?       @relation(fields: [categoryId], references: [id])
  categoryId       String?
  type             TransactionType
  originalAmount   Int
  originalCurrency Currency
  amountDkk        Int
  exchangeRate     Decimal?        @db.Decimal(10, 6)
  description      String?
  occurredAt       DateTime
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum Currency {
  DKK
  BRL
}

model ExchangeRate {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  fromCurrency Currency
  toCurrency   Currency
  rate         Decimal  @db.Decimal(14, 8)
  note         String?
  fetchedAt    DateTime @default(now())

  @@unique([date, fromCurrency, toCurrency])
}

model CalendarEvent {
  id             String          @id @default(cuid())
  title          String
  category       CalendarCategory @relation(fields: [categoryId], references: [id])
  categoryId     String
  person         User?           @relation(fields: [personId], references: [id])
  personId       String?
  startAt        DateTime
  allDay         Boolean         @default(true)
  recurrence     RecurrenceType  @default(NONE)
  recurrenceDays Int[]           @default([])
  description    String?
  createdBy      User            @relation("EventCreator", fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum RecurrenceType {
  NONE
  YEARLY
  WEEKLY
}

model CalendarCategory {
  id        String          @id @default(cuid())
  name      String
  color     String
  icon      String
  events    CalendarEvent[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ShoppingListItem {
  id            String      @id @default(cuid())
  user          User        @relation(fields: [userId], references: [id])
  userId        String
  name          String
  checked       Boolean     @default(false)
  matchedOffer  FlyerOffer? @relation(fields: [matchedOfferId], references: [id])
  matchedOfferId String?
  matchedAt     DateTime?
  matchNote     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model FlyerOffer {
  id           String             @id @default(cuid())
  externalId   String             @unique
  dealerId     String
  dealerName   String
  name         String
  priceOre     Int
  prePriceOre  Int?
  validFrom    DateTime
  validUntil   DateTime
  fetchedAt    DateTime           @default(now())
  items        ShoppingListItem[]
}

model AiUsageLog {
  id             String   @id @default(cuid())
  provider       String   // "gemini"
  model          String
  service        String
  inputTokens    Int
  outputTokens   Int
  createdAt      DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model NotificationLog {
  id              String            @id @default(cuid())
  type            NotificationType
  calendarEventId String?
  reminderStage   ReminderStage?
  pokeMessageId   String?
  fromUserId      String?
  toUserId        String
  toUser          User              @relation(fields: [toUserId], references: [id])
  title           String
  body            String
  read            Boolean           @default(false)
  sentAt          DateTime          @default(now())
}

enum NotificationType {
  EVENT_REMINDER
  POKE
}

enum ReminderStage {
  DAY_BEFORE
  DAY_OF
}

model MaintenanceTask {
  id            String   @id @default(cuid())
  title         String
  description   String
  frequency     String   // DAILY | WEEKLY | MONTHLY | SEMESTRAL | YEARLY
  category      String   // ex: "Cozinha", "Banheiro", "Eletrodomésticos", "Geral"
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  logs          MaintenanceLog[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MaintenanceLog {
  id          String   @id @default(cuid())
  task        MaintenanceTask @relation(fields: [taskId], references: [id])
  taskId      String
  doneBy      User     @relation(fields: [doneById], references: [id])
  doneById    String
  doneAt      DateTime @default(now())
}

model WorkoutLog {
  id               String    @id @default(cuid())
  personId         String
  person           User      @relation(fields: [personId], references: [id])
  type             WorkoutType
  durationMinutes  Int?
  intensity        WorkoutIntensity?
  note             String?
  date             DateTime
  createdAt        DateTime  @default(now())
}

enum WorkoutType {
  MUSCULACAO
  CORRIDA
  NATACAO
  YOGA
  CAMINHADA
  FUTEBOL
  BASQUETE
  OUTRO
}

enum WorkoutIntensity {
  LEVE
  MODERADO
  INTENSO
}

model WeeklyResult {
  id           String   @id @default(cuid())
  weekStart    DateTime @unique
  countPedro   Int
  countAna     Int
  winnerId     String?
  winner       User?    @relation("WeeklyWinner", fields: [winnerId], references: [id])
  createdAt    DateTime @default(now())
}

enum SuggestionKind {
  EVENT
  MOVIE
}

enum SuggestionStatus {
  NEW
  DISMISSED
  ADDED
}

model UserInterest {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  label       String
  createdAt   DateTime @default(now())

  @@unique([userId, label])
}

model EventSuggestion {
  id          String   @id @default(cuid())
  source      String   // "ticketmaster" | "hidden_nordvest" | "nv_and_more" | "kulturkbh" | "tmdb"
  externalId  String   @unique
  title       String
  description String?
  venueName   String?
  city        String?
  startAt     DateTime
  url         String?
  imageUrl    String?
  category    String?
  kind        SuggestionKind   @default(EVENT)
  status      SuggestionStatus @default(NEW)
  createdAt   DateTime @default(now())

  relevances  EventSuggestionRelevance[]
}

model EventSuggestionRelevance {
  id                String          @id @default(cuid())
  eventSuggestion   EventSuggestion @relation(fields: [eventSuggestionId], references: [id], onDelete: Cascade)
  eventSuggestionId String
  user              User            @relation(fields: [userId], references: [id])
  userId            String
  reason            String?

  @@unique([eventSuggestionId, userId])
}
